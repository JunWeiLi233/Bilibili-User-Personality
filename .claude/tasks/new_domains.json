  "rounds": [
    {
      "id": 1,
      "label": "R1: scrape top-20 per new seed (pages=1, metadata only)",
      "outputDir": ".claude/seed_results_newdomain",
      "videoSource": { "type": "search-api", "pages": 1, "pageSize": 20 },
      "videoCount": 20,
      "pages": 1,
      "danmakuCap": 0,
      "metadataOnly": true
    },
    {
      "id": 2,
      "label": "R2: deep scrape top-5 (pages=5, danmaku=1000)",
      "outputDir": ".claude/seed_results_newdomain_deep",
      "videoSource": { "type": "prior-round", "roundId": 1, "topN": 5 },
      "videoCount": 5,
      "pages": 5,
      "danmakuCap": 1000,
      "deepenMatch": true,
      "deepenRootLimit": 10,
      "deepenPages": 3
    },
    {
      "id": 3,
      "label": "R3: scrape videos 6-15 (pages=3, danmaku=500)",
      "outputDir": ".claude/seed_results_newdomain_batch2",
      "videoSource": { "type": "prior-round", "roundId": 1, "topN": 15, "skipN": 5 },
      "videoCount": 10,
      "pages": 3,
      "danmakuCap": 500
    },
    {
      "id": 4,
      "label": "R4: harvest new-domain evidence",
      "type": "harvest",
      "sourceDirs": [
        ".claude/seed_results_newdomain",
        ".claude/seed_results_newdomain_deep",
        ".claude/seed_results_newdomain_batch2"
