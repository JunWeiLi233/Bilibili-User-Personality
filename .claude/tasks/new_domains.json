    "tech": ["AI", "大模型", "芯片", "华为", "小米", "iPhone", "自动驾驶", "程序员", "人工智能", "GPU", "Linux", "开源", "前端", "后端", "面试", "互联网", "996", "裁员", "创业", "产品经理"],
    "social": ["房价", "教育", "考研", "考公", "就业", "结婚", "彩礼", "生育", "医疗", "股市", "基金", "比特币", "直播", "短视频", "外卖", "网约车", "学历", "内卷", "躺平", "润"]
