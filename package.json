    "python:huggingface-import": "python -m python_backend.cli.huggingface_corpus",
    "python:history-tags": "python -m python_backend.cli.history_tag_corpus",
    "python:bilibili-crawler": "python -m python_backend.cli.bilibili_crawler",
    "python:bilibili-parse": "python -m python_backend.cli.bilibili_parse",
    "python:bilibili-probe-plan": "python -m python_backend.cli.bilibili_probe_plan",
    "python:tieba-html-parse": "python -m python_backend.cli.tieba_html_parse",
    "python:tieba-timing": "python -m python_backend.cli.tieba_timing",
    "python:flatten-local": "python -m python_backend.cli.local_corpus_flatten",
    "python:local-evidence": "python -m python_backend.cli.local_corpus_evidence",
    "python:video-comment-filter": "python -m python_backend.cli.video_comment_filter",
